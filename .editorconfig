# sumi — consistent coding defaults across editors
root = true

[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
indent_style = space
indent_size = 4

[*.{sh,bash,zsh}]
indent_size = 4

[*.{js,jsx,ts,tsx,json,css,html,yaml,yml,toml}]
indent_size = 2

[*.lua]
indent_size = 4

[*.{md,markdown}]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.go]
indent_style = tab

[*.{conf,ini,cfg}]
indent_size = 4

[*.py]
indent_size = 4
max_line_length = 88
