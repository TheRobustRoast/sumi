*.pyc
__pycache__/

# Session saves are per-machine
sessions/

# Crash logs
crash.log

# Local nvim state
nvim/lazy-lock.json
nvim/plugin/

# Wallpapers (user content, too large for git)
wallpapers/

.claude/settings.local.json
